# Gemini REST API key from Google AI Studio. Never commit a real key.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Optional Gemini model override. The app defaults to gemini-2.5-flash.
GEMINI_MODEL=gemini-2.5-flash

# Google Maps SDK for Android key. Restrict it to the Android package and signing certificate.
MAPS_API_KEY=YOUR_GOOGLE_MAPS_ANDROID_KEY
